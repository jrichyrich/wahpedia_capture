    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "1 Veteran Guardsman\u2019s boltgun can be replaced with one of the following:",
          "items": [
            "1 flamer",
            "1 grenade launcher",
            "1 meltagun",
            "1 plasma gun"
          ]
        },
        {
          "type": "option_group",
          "label": "The Lord Commissar's power weapon can be replaced with 1 power fist.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "The Lord Commissar can be equipped with 1 plasma pistol.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Veteran Guardsman\u2019s chainsword can be replaced with one of the following:",
          "items": [
            "1 trench club",
            "1 power weapon"
          ]
        },
        {
          "type": "option_group",
          "label": "1 Veteran Guardsman not equipped with alchemyk counteragents can replace its laspistol with one of the following:",
          "items": [
            "1 bolt pistol",
            "1 plasma pistol"
          ]
        }
      ]
    },
