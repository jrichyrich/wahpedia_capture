  "sections": [
    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "Any number of Tempestus Scions can each have their hot-shot lasgun replaced with one of the following*:",
          "items": [
            "1 flamer",
            "1 grenade launcher",
            "1 hot-shot volley gun",
            "1 meltagun",
            "1 plasma gun"
          ]
        },
        {
          "type": "option_group",
          "label": "1 Tempestus Scion equipped with a hot-shot lasgun can be equipped with 1 regimental standard (that model\u2019s hot-shot lasgun cannot be replaced).",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Tempestus Scion\u2019s hot-shot lasgun can be replaced with 1 hot-shot laspistol and 1 master vox.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Tempestus Scion\u2019s hot-shot lasgun can be replaced with one of the following:",
          "items": [
            "1 hot-shot laspistol and 1 medi-pack",
            "1 hot-shot lasgun, 1 hot-shot laspistol and 1 medi-pack [that model's hot-shot lasgun cannot be replaced]"
          ]
        },
        {
          "type": "option_group",
          "label": "The Tempestor Prime\u2019s bolt pistol can be replaced with one of the following:",
          "items": [
            "1 plasma pistol",
            "1 command rod"
          ]
        },
        {
          "type": "text",
          "text": "* You cannot select the same weapon from this list more than once per unit."
        }
      ]
    },
    {
      "title": "ABILITIES",
      "entries": [
        {
          "type": "tagged_list",
