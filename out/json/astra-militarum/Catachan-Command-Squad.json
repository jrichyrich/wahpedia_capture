  "sections": [
    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "Any number of Veteran Guardsmen can each have their lasgun replaced with one of the following*:",
          "items": [
            "1 flamer",
            "1 grenade launcher",
            "1 heavy flamer",
            "1 meltagun",
            "1 plasma gun",
            "1 sniper rifle"
          ]
        },
        {
          "type": "option_group",
          "label": "Veteran Guardsman equipped with a lasgun can be equipped with 1 master vox.**",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Veteran Guardsman equipped with a lasgun can be equipped 1 medi-pack.**",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Veteran Guardsman equipped with a lasgun can be equipped with 1 regimental standard.**",
          "items": []
        },
        {
          "type": "option_group",
          "label": "The Catachan Commander\u2019s laspistol can be replaced with one of the following:",
          "items": [
            "1 bolt pistol",
            "1 plasma pistol"
          ]
        },
        {
          "type": "option_group",
          "label": "The Catachan Commander can be equipped with one of the following:",
          "items": [
            "1 boltgun",
            "1 chainsword",
            "1 power fist",
            "1 power weapon"
          ]
        },
        {
          "type": "text",
          "text": "* You cannot select the same weapon from this list more than once per unit."
        },
        {
          "type": "text",
          "text": "** A model can only take one of these options."
        }
      ]
    },
    {
      "title": "ABILITIES",
      "entries": [
