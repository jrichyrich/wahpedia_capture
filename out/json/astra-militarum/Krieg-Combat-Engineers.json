      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "1 Krieg Combat Engineer's autopistol and trench club can be replaced with 1 flamer and 1 close combat weapon.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Krieg Combat Engineer\u2019s autopistol and trench club can be replaced with 1 autopistol, 1 remote mine and 1 close combat weapon.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Any number of models can each have their autopistol and trench club replaced with 1 combat shotgun and 1 close combat weapon.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "The Krieg Engineer Watchmaster\u2019s autopistol can be replaced with one of the following:",
