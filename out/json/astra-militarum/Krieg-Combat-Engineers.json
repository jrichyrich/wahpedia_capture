    {
      "title": "WARGEAR ABILITIES",
      "entries": [
        {
          "type": "statement",
          "text": "Once per battle, at the start of your Shooting phase , you can select one enemy unit within 9\" of and visible to the bearer and roll one D6: on a 3+, that enemy unit suffers D3 mortal wounds , or 2D3 mortal wounds instead if it is a VEHICLE or FORTIFICATIONS unit.",
          "label": "Remote Mine"
        },
        {
          "type": "statement",
          "text": "Place a Remote Mine token next to the unit, removing it once this ability has been used.",
          "label": "Designer\u2019s Note"
        }
      ]
