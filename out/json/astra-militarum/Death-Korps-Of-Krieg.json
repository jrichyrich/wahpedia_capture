  "sections": [
    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "For every 10 models in this unit, up to 2 Death Korps Troopers can each have their lasgun replaced with one of the following*:",
          "items": [
            "1 flamer",
            "1 grenade launcher",
            "1 long-las",
            "1 meltagun",
            "1 plasma gun"
          ]
        },
        {
          "type": "option_group",
          "label": "For every 10 models in this unit, 1 Death Korps Trooper equipped with a lasgun can be equipped with 1 Death Korps medi-pack (that model\u2019s lasgun cannot be replaced)**.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "For every 10 models in this unit, 1 Death Korps Trooper equipped with a lasgun can be equipped with 1 vox-caster (that model\u2019s lasgun cannot be replaced).**",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Any number of Death Korps Watchmasters can each replace their laspistol and chainsword with 1 boltgun and 1 close combat weapon.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Any number of Death Korps Watchmasters can each replace their chainsword with 1 power weapon.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Any number of Death Korps Watchmasters can each replace their laspistol with one of the following:",
          "items": [
            "1 bolt pistol",
            "1 plasma pistol"
          ]
        },
        {
          "type": "text",
          "text": "* You cannot select the same option more than once per unit unless it contains 20 models, in which case you cannot select the same option more than twice per unit."
        },
        {
          "type": "text",
          "text": "** A model can only take one of these options."
        }
      ]
    },
    {
      "title": "ABILITIES",
      "entries": [
        {
          "type": "text",
          "text": "Grim Demeanour: Each time a model in this unit makes an attack, add 1 to the Hit roll if this unit is below its Starting Strength , and add 1 to the Wound roll as well if this unit is Below Half-strength ."
        }
      ]
    },
    {
      "title": "WARGEAR ABILITIES",
      "entries": [
        {
          "type": "text",
          "text": "Vox-caster: Each time you target the bearer\u2019s unit with a Stratagem , roll one D6, adding 1 to the result if there are one or more friendly OFFICER models within 6\": on a 5+, you gain 1CP. Death Korps Medi-pack: At the start of your Command phase , if the bearer\u2019s unit is below its Starting Strength , you can return up to D3 destroyed Death Korps Troopers to this unit (if this unit contains two models equipped with a Death Korps medi-pack, return up to D3+1 destroyed Death Korps Troopers to this unit instead)."
        }
      ]
    },
    {
