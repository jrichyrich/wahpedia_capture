    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "For every 10 models in this unit, up to 2 Shock Troopers can each have their lasgun replaced with one of the following*:",
          "items": [
            "1 flamer",
            "1 grenade launcher",
            "1 meltagun",
            "1 plasma gun"
          ]
        },
        {
          "type": "option_group",
          "label": "For every 10 models in this unit, 1 Shock Trooper equipped with a lasgun can be equipped with 1 vox-caster (that model\u2019s lasgun cannot be replaced).",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Any number of Shock Trooper Sergeants can each have their laspistol replaced with 1 bolt pistol.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "Any number of Shock Trooper Sergeants can each have their laspistol and chainsword replaced with 1 Sergeant's autogun and 1 close combat weapon.",
          "items": []
        },
        {
          "type": "text",
          "text": "* You cannot select the same weapon more than once per unit unless it contains 20 models, in which case you cannot select the same weapon more than twice per unit."
        }
      ]
    },
