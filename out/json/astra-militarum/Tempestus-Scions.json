    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "For every 5 models in this unit, up to two Tempestus Scions can each have their hot-shot lasgun replaced with one of the following*:",
          "items": [
            "1 flamer",
            "1 grenade launcher",
            "1 hot-shot volley gun",
            "1 meltagun",
            "1 plasma gun"
          ]
        },
        {
          "type": "option_group",
          "label": "1 Tempestus Scion\u2019s hot-shot lasgun can be replaced with 1 hot-shot laspistol and 1 vox-caster.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "The Tempestor\u2019s chainsword can be replaced with one of the following:",
          "items": [
            "1 power fist",
            "1 power weapon"
          ]
        },
        {
          "type": "option_group",
          "label": "The Tempestor\u2019s hot-shot laspistol can be replaced with one of the following:",
          "items": [
            "1 bolt pistol",
            "1 plasma pistol"
          ]
        },
        {
          "type": "text",
          "text": "* You cannot select the same weapon from this list more than once per unit, unless this unit contains 10 models, in which case you cannot select the same weapon more than twice per unit."
        }
      ]
    },
