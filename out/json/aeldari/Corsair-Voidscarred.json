      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "Any number of Corsair Voidscarred can each have their shuriken pistol and power sword replaced with 1 shuriken rifle.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "The Voidscarred Felarch\u2019s shuriken pistol can be replaced with one of the following:",
          "items": [
            "1 neuro disruptor",
            "1 shuriken rifle"
          ]
        },
        {
          "type": "option_group",
          "label": "The Voidscarred Felarch can be equipped with 1 mistshield.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "For every 5 models in this unit, 1 Corsair Voidscarred\u2019s shuriken rifle can be replaced with one of the following:",
          "items": [
            "1 blaster",
            "1 shredder"
          ]
        },
        {
          "type": "option_group",
          "label": "If this unit contains 10 models, 1 Corsair Voidscarred\u2019s shuriken rifle can be replaced with one of the following:",
          "items": [
            "1 shuriken cannon",
            "1 wraithcannon"
          ]
        },
        {
          "type": "option_group",
          "label": "If this unit contains 10 models, 1 Corsair Voidscarred\u2019s shuriken rifle can be replaced with 1 long rifle.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "If this unit contains 10 models, 1 Corsair Voidscarred\u2019s power sword can be replaced with 1 fusion pistol.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Corsair Voidscarred model equipped with a shuriken pistol and power sword can be equipped with 1 Faolch\u00fa.",
