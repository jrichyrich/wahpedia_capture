    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "Any number of Deathwing Command Terminators can each have their storm bolter and power fist replaced with one of the following:",
          "items": [
            "1 twin lightning claws",
            "1 thunder hammer and 1 storm shield"
          ]
        },
        {
          "type": "option_group",
          "label": "Any number of Deathwing Command Terminators can each have their power fist replaced with 1 chainfist.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "1 Deathwing Command Terminator\u2019s power fist can be replaced with 1 power weapon.",
          "items": []
        },
        {
          "type": "option_group",
          "label": "For every 5 models in this unit, 1 Deathwing Command Terminator can replace its storm bolter with one of the following:",
          "items": [
            "1 assault cannon",
            "1 heavy flamer",
            "1 plasma cannon",
            "1 storm bolter and 1 cyclone missile launcher (this model\u2019s storm bolter cannot be replaced)"
          ]
        },
        {
          "type": "option_group",
          "label": "This unit can be equipped with 1 Watcher in the Dark.*",
          "items": []
        },
        {
          "type": "text",
