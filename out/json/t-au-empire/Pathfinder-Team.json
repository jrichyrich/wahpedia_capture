  "sections": [
    {
      "title": "WARGEAR OPTIONS",
      "entries": [
        {
          "type": "option_group",
          "label": "The Pathfinder Shas\u2019ui can be equipped with one of the following:",
          "items": [
            "1 grav-inhibitor drone",
            "1 pulse accelerator drone",
            "1 recon drone"
          ]
        },
        {
          "type": "option_group",
          "label": "The Pathfinder Shas\u2019ui can be equipped with up to two of the following, and can take duplicates:",
          "items": [
            "1 gun drone",
            "1 marker drone",
            "1 shield drone"
          ]
        },
        {
          "type": "option_group",
          "label": "Up to 3 Pathfinders can each have their pulse carbine replaced with one of the following:",
          "items": [
            "1 ion rifle",
            "1 rail rifle"
          ]
        },
        {
          "type": "option_group",
          "label": "1 model in this unit equipped with a pulse carbine can be equipped with 1 semi-automatic grenade launcher. That model\u2019s pulse carbine cannot be replaced.",
          "items": []
        }
      ]
    },
